# Your Confluence Cloud domain (e.g., "yourcompany" for yourcompany.atlassian.net)
CONFLUENCE_DOMAIN=yourcompany

# The email address associated with your Atlassian account
CONFLUENCE_EMAIL=you@example.com

# API token generated at https://id.atlassian.net/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-api-token-here

# The Confluence space key to export (found in the space URL or settings)
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
